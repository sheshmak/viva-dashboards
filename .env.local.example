# ──────────────────────────────────────────────────────────────────────────────
# Wrike OAuth App Credentials
# Register your app at: https://developer.wrike.com/api/oauth2/
# Set Redirect URI to: http://localhost:3000/api/connections/wrike/callback
# ──────────────────────────────────────────────────────────────────────────────
WRIKE_CLIENT_ID=your_wrike_client_id_here
WRIKE_CLIENT_SECRET=your_wrike_client_secret_here

# ──────────────────────────────────────────────────────────────────────────────
# NextAuth.js Secret (generate with: openssl rand -base64 32)
# ──────────────────────────────────────────────────────────────────────────────
AUTH_SECRET=your_nextauth_secret_here

# ──────────────────────────────────────────────────────────────────────────────
# App URL (change to your production URL when deploying)
# ──────────────────────────────────────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000

# ──────────────────────────────────────────────────────────────────────────────
# SQLite database (used by legacy admin routes — not required for the schedule
# dashboard; keep to avoid Prisma init errors on the old API routes)
# ──────────────────────────────────────────────────────────────────────────────
DATABASE_URL="file:./dev.db"
